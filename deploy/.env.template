# ═══════════════════════════════════════════════════════════════════════
# Legal Partner — Customer Configuration Template
# Copy to deploy/customers/<name>/.env and fill in values
# ═══════════════════════════════════════════════════════════════════════

# ── Docker Images ────────────────────────────────────────────────────
DOCKERHUB_USERNAME=jyoti0512shukla
IMAGE_TAG=latest                          # Pin to git SHA for rollback (e.g., abc1234)
# FRONTEND_PORT=80                        # Change if 80 is taken

# ── Database (REQUIRED) ─────────────────────────────────────────────
DB_PASSWORD=                              # Generate: openssl rand -base64 32

# ── Security (REQUIRED) ─────────────────────────────────────────────
ENCRYPTION_KEY=                           # Generate: openssl rand -base64 32
JWT_SECRET=                               # Generate: openssl rand -base64 48 (min 256-bit)

# ── URLs (REQUIRED) ─────────────────────────────────────────────────
LEGALPARTNER_APP_URL=                     # e.g., https://sharmalaw.legal-ai.studio
LEGALPARTNER_CLOUD_FRONTEND_URL=          # Same as above, or http://<IP>:80
LEGALPARTNER_CLOUD_BACKEND_URL=           # e.g., https://sharmalaw.legal-ai.studio/api

# ── LLM — Chat Model ────────────────────────────────────────────────
LEGALPARTNER_CHAT_PROVIDER=gemini         # gemini or vllm
LEGALPARTNER_GEMINI_API_KEY=              # Required if provider=gemini
LEGALPARTNER_GEMINI_MODEL=gemini-2.5-flash
# LEGALPARTNER_CHAT_API_URL=              # Required if provider=vllm (OpenAI-compatible URL)
# LEGALPARTNER_CHAT_API_MODEL=            # Model name for vllm provider

# ── LLM — Embeddings (Ollama, runs locally) ─────────────────────────
LEGALPARTNER_OLLAMA_MODEL=all-minilm      # Embedding model, auto-pulled on first start

# ── Email / SMTP (optional) ─────────────────────────────────────────
LEGALPARTNER_MAIL_ENABLED=false
LEGALPARTNER_MAIL_FROM=noreply@legalpartner.local
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_SSL_ENABLE=true
# SMTP_STARTTLS_ENABLE=false

# ── Document Editor — OnlyOffice (optional) ─────────────────────────
# Uncomment to enable OnlyOffice document editing
# COMPOSE_PROFILES=onlyoffice
# LEGALPARTNER_ONLYOFFICE_URL=http://<VM-IP>:8443

# ── Cloud Storage (optional, all disabled by default) ────────────────
# LEGALPARTNER_GOOGLE_DRIVE_ENABLED=false
# LEGALPARTNER_GOOGLE_DRIVE_CLIENT_ID=
# LEGALPARTNER_GOOGLE_DRIVE_CLIENT_SECRET=
# LEGALPARTNER_ONEDRIVE_ENABLED=false
# LEGALPARTNER_ONEDRIVE_CLIENT_ID=
# LEGALPARTNER_ONEDRIVE_CLIENT_SECRET=
# LEGALPARTNER_DROPBOX_ENABLED=false
# LEGALPARTNER_DROPBOX_APP_KEY=
# LEGALPARTNER_DROPBOX_APP_SECRET=

# ── E-Signature (optional) ──────────────────────────────────────────
# LEGALPARTNER_DOCUSIGN_ENABLED=false
# LEGALPARTNER_DOCUSIGN_CLIENT_ID=
# LEGALPARTNER_DOCUSIGN_CLIENT_SECRET=
# LEGALPARTNER_DOCUSIGN_ENV=demo

# ── Collaboration (optional) ────────────────────────────────────────
# LEGALPARTNER_SLACK_ENABLED=false
# LEGALPARTNER_TEAMS_ENABLED=false

# ── DMS Integrations (optional) ─────────────────────────────────────
